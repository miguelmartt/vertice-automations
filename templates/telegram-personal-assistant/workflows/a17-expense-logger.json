    {
      "parameters": {
        "jsCode": "// Allowlist: only react to your own chat id. Set YOUR_CHAT_ID (numeric).\nconst ALLOWED_CHAT_ID = 'YOUR_CHAT_ID';\nconst msg = $json.message || {};\nconst chatId = String(msg.chat && msg.chat.id);\nif (chatId !== String(ALLOWED_CHAT_ID)) {\n  return [];\n}\nreturn [{ json: { text: (msg.text || '').trim(), chatId } }];"
      },
      "id": "a1700000-0000-4000-8000-000000000002",
      "name": "Only my chat",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 380]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "id": "cond-summary",
              "leftValue": "={{ $json.text }}",
              "rightValue": "/mes",
              "operator": { "type": "string", "operation": "startsWith" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1700000-0000-4000-8000-000000000003",
      "name": "Is /mes summary?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [640, 380]
    },
    {
      "parameters": {
        "jsCode": "// Parse a free-text expense like \"12 comida\", \"12€ comida\", \"comida 12,50\".\n// Output: date, amount, currency, category, note.\nconst raw = ($json.text || '').trim();\nconst amountMatch = raw.match(/(\\d+[.,]?\\d*)\\s*(€|eur|euros|\\$|usd)?/i);\nif (!amountMatch) {\n  return [{ json: { ok: false, reply: 'No pude leer el importe. Escribe algo como: 12 comida' } }];\n}\nconst amount = parseFloat(amountMatch[1].replace(',', '.'));\nlet currency = (amountMatch[2] || '€').toUpperCase();\nif (currency === 'EUR' || currency === 'EUROS') currency = '€';\nif (currency === 'USD') currency = '$';\n// Everything that is not the amount/currency token becomes the description.\nconst note = raw.replace(amountMatch[0], '').replace(/[€$]/g, '').trim() || '(sin categoría)';\nconst category = note.split(/\\s+/)[0].toLowerCase();\nconst date = new Date().toISOString().slice(0, 10);\nreturn [{ json: { ok: true, date, amount, currency, category, note, reply: `💸 Registrado: ${amount}${currency} · ${note}` } }];"
      },
      "id": "a1700000-0000-4000-8000-000000000004",
      "name": "Parse expense",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 480]
    },
    {
      "parameters": {
        "operation": "append",
