      "id": "a1700000-0000-4000-8000-000000000007",
      "name": "Read all rows",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [880, 240],
      "credentials": {
        "googleSheetsOAuth2Api": { "id": "REPLACE_ME", "name": "Google Sheets account" }
      }
