    {
      "parameters": {
        "jsCode": "// Sum this month's expenses grouped by category.\nconst ym = new Date().toISOString().slice(0, 7); // YYYY-MM\nconst rows = $input.all().map((it) => it.json);\nconst mine = rows.filter((r) => String(r.Date || '').startsWith(ym));\nif (!mine.length) {\n  return [{ json: { reply: `📊 ${ym}: aún no hay gastos registrados este mes.` } }];\n}\nlet total = 0;\nconst byCat = {};\nfor (const r of mine) {\n  const a = parseFloat(String(r.Amount).replace(',', '.')) || 0;\n  total += a;\n  const c = r.Category || '(otros)';\n  byCat[c] = (byCat[c] || 0) + a;\n}\nconst cur = mine[0].Currency || '€';\nconst lines = Object.entries(byCat)\n  .sort((a, b) => b[1] - a[1])\n  .map(([c, v]) => `• ${c}: ${v.toFixed(2)}${cur}`);\nconst reply = `📊 Gastos de ${ym}\\nTotal: ${total.toFixed(2)}${cur} en ${mine.length} apuntes\\n\\n${lines.join('\\n')}`;\nreturn [{ json: { reply } }];"
      },
      "id": "a1700000-0000-4000-8000-000000000008",
